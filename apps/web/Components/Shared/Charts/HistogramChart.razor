@using Web.DermaImage.Shared.Models

@if (Data.Count == 0 || maxValue <= 0)
{
    <div class="chart-empty">@EmptyMessage</div>
}
else
{
    <div class="histogram-apex">
        <ApexChart @ref="apexChart" TItem="ChartPoint" Options="chartOptions" Height="280">
            <ApexPointSeries TItem="ChartPoint"
                             Items="Data"
                             Name="@SeriesName"
                             SeriesType="SeriesType.Bar"
                             XValue="@(x => x.Label)"
                             YValue="@(x => (decimal?)x.Value)" />
        </ApexChart>
    </div>
}

@code {
    [Parameter] public IReadOnlyList<ChartPoint> Data { get; set; } = [];
    [Parameter] public string EmptyMessage { get; set; } = "Sin datos disponibles.";
    [Parameter] public string ColorClass { get; set; } = "histogram-fill--primary";
    [Parameter] public string SeriesName { get; set; } = "Total";

    private ApexChart<ChartPoint> apexChart = null!;
    private ApexChartOptions<ChartPoint> chartOptions = new();
    private double maxValue => Data.Count == 0 ? 0 : Data.Max(x => x.Value);

    protected override void OnParametersSet()
    {
        var color = ChartTheme.ResolveHistogramColor(ColorClass);
        var categories = Data.Select(x => x.Label).ToList();
        chartOptions = ChartTheme.BuildBarOptions<ChartPoint>([color], categories, showLegend: false);
    }
}
