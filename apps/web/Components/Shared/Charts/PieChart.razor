@using Web.DermaImage.Shared.Models
@using ApexCharts
@using Web.DermaImage.Components.Shared.Charts

@if (Data.Count == 0 || total <= 0)
{
    <div class="chart-empty">@EmptyMessage</div>
}
else
{
    <div class="pie-layout">
        <div class="pie-donut-wrapper">
            <ApexChart TItem="ChartPoint"
                       Options="options"
                       Height="200"
                       Width="200">
                <ApexPointSeries TItem="ChartPoint"
                                 Items="Data"
                                 Name="Distribución"
                                 SeriesType="SeriesType.Donut"
                                 XValue="@(e => e.Label)"
                                 YValue="@(e => (decimal)e.Value)" />
            </ApexChart>
        </div>

        <ul class="pie-legend">
            @for (var i = 0; i < points.Count; i++)
            {
                var item = points[i];
                <li>
                    <span class="pie-dot" style="background: @colors[i];"></span>
                    <span class="pie-label">@item.Label</span>
                    <span class="pie-value">@item.Value.ToString("0") (@item.Percentage.ToString("0.0")%)</span>
                </li>
            }
        </ul>
    </div>
}

@code {
    [Parameter] public IReadOnlyList<ChartPoint> Data { get; set; } = [];
    [Parameter] public string EmptyMessage { get; set; } = "Sin datos disponibles.";

    private double total;
    private ApexChartOptions<ChartPoint> options = new();
    private List<ChartPointView> points = [];
    private List<string> colors = [];

    protected override void OnParametersSet()
    {
        total = Data.Sum(x => x.Value);
        points.Clear();
        
        if (total <= 0) return;

        var labels = Data.Select(x => x.Label).ToList();
        colors = ChartTheme.BuildSeriesColors(Data.Count);
        
        for (var i = 0; i < Data.Count; i++)
        {
            points.Add(new ChartPointView
            {
                Label = Data[i].Label,
                Value = Data[i].Value,
                Percentage = (Data[i].Value / total) * 100d
            });
        }

        options = ChartTheme.BuildDonutOptions<ChartPoint>(colors, labels, "Total");
        options.Legend.Show = false; // Maintain our custom HTML legend
        options.DataLabels = new DataLabels 
        { 
            Enabled = true,
            Formatter = "function (val, opts) { return opts.w.config.series[opts.seriesIndex]; }",
            Style = new DataLabelsStyle { FontSize = "14px", FontFamily = "var(--font-display)", FontWeight = "800" },
            DropShadow = new DropShadow { Enabled = true, Top = 1, Left = 0, Blur = 2, Opacity = 0.5 }
        };
        options.PlotOptions.Pie = new PlotOptionsPie
        {
            Donut = new PlotOptionsDonut
            {
                Size = "60%",
                Labels = new DonutLabels
                {
                    Show = true,
                    Name = new DonutLabelName { Show = false },
                    Value = new DonutLabelValue { Show = true, FontSize = "22px", FontWeight = "bold", Color = "var(--on-surface)" },
                    Total = new DonutLabelTotal
                    {
                        Show = true,
                        ShowAlways = true,
                        Label = "Total",
                        FontSize = "12px",
                        Color = "var(--on-surface-variant)",
                        Formatter = "function (w) { return w.globals.seriesTotals.reduce((a, b) => a + b, 0).toFixed(0); }"
                    }
                }
            }
        };
    }

    private sealed class ChartPointView
    {
        public string Label { get; set; } = string.Empty;
        public double Value { get; set; }
        public double Percentage { get; set; }
    }
}
