@using Web.DermaImage.Shared.Models
@using Blazorise
@using Blazorise.Maps

@if (Data.Count == 0)
{
    <div class="chart-empty">@EmptyMessage</div>
}
else
{
    <div class="cuba-map-wrapper">
        <div class="cuba-map-container">
            <Map View="@mapView"
                 Options="@mapOptions"
                 Height="Blazorise.Height.Px(480)">
                <MapTileLayer
                    Source="https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png"
                    Subdomains="@(new[] { "a", "b", "c", "d" })"
                    Attribution="&copy; <a href='https://www.openstreetmap.org/copyright'>OSM</a> &copy; <a href='https://carto.com/'>CARTO</a>"
                    MaxZoom="18" />

                @foreach (var province in provinceMarkers)
                {
                    var data = GetProvinceData(province.Key);
                    if (data is not null && data.Count > 0)
                    {
                        var radius = ComputeRadius(data.Count);
                        var color = ComputeColor(data.Count);

                        <MapCircle Center="@province.Coordinate"
                                   Radius="@radius"
                                   Style="@(new MapShapeStyle
                                   {
                                       StrokeColor = color,
                                       StrokeWidth = 2,
                                       FillColor = color,
                                       FillOpacity = 0.45
                                   })" />

                        <MapMarker Coordinate="@province.Coordinate"
                                   Title="@data.Label"
                                   PopupText="@($"<div style='text-align:center;font-family:sans-serif'><strong style='font-size:14px;color:#e2e8f0'>{data.Label}</strong><br/><span style='font-size:22px;font-weight:800;color:{color}'>{data.Count}</span><br/><span style='font-size:11px;color:#94a3b8'>imágenes ({data.Percentage:F1}%)</span></div>")"
                                   Icon="@(new MapMarkerIcon
                                   {
                                       Source = $"data:image/svg+xml,{Uri.EscapeDataString(BuildSvgMarker(data.Count, color))}",
                                       Size = new(40, 40),
                                       Anchor = new(20, 20)
                                   })" />
                    }
                }
            </Map>
        </div>

        @* ── Province Legend / Table ── *@
        <div class="cuba-detail-panel">
            <h3 class="detail-title">
                <span class="detail-icon">📊</span>
                Datos por provincia
            </h3>
            <div class="detail-scroll">
                <table class="cuba-table">
                    <thead>
                        <tr>
                            <th>Provincia</th>
                            <th class="cuba-num">Imgs</th>
                            <th class="cuba-num">%</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in orderedData)
                        {
                            var color = ComputeColor(p.Count);
                            <tr>
                                <td>
                                    <span class="cuba-dot" style="background: @color"></span>
                                    @p.Label
                                </td>
                                <td class="cuba-num">@p.Count</td>
                                <td class="cuba-num pct">@p.Percentage.ToString("F1")%</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Gradient legend *@
            <div class="gradient-legend">
                <span class="gradient-label">Baja</span>
                <div class="gradient-bar"></div>
                <span class="gradient-label">Alta</span>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public IReadOnlyList<StatisticsBucketDto> Data { get; set; } = [];
    [Parameter] public string EmptyMessage { get; set; } = "Sin datos de provincia disponibles.";

    // Center of Cuba
    private MapView mapView = new()
    {
        Center = new(21.5218, -79.3812),
        Zoom = 6.4
    };

    private MapOptions mapOptions = new()
    {
        Controls = new MapControlOptions { ShowZoom = true },
        ZoomOnScroll = true,
    };

    private IReadOnlyList<StatisticsBucketDto> orderedData = [];

    protected override void OnParametersSet()
    {
        orderedData = Data.OrderByDescending(x => x.Count).ToList();
    }

    private StatisticsBucketDto? GetProvinceData(string key)
        => Data.FirstOrDefault(d => string.Equals(d.Key, key, StringComparison.OrdinalIgnoreCase));

    private int maxCount => Data.Count > 0 ? Data.Max(d => d.Count) : 1;

    /// <summary>Circle radius in meters scaled to data density.</summary>
    private double ComputeRadius(int count)
    {
        var ratio = (double)count / Math.Max(1, maxCount);
        return 8000 + ratio * 28000; // 8km to 36km
    }

    /// <summary>Interpolate between teal and vivid magenta based on count.</summary>
    private string ComputeColor(int count)
    {
        var ratio = Math.Clamp((double)count / Math.Max(1, maxCount), 0, 1);
        // From #06b6d4 (cyan-500) through #8b5cf6 (violet-500) to #ec4899 (pink-500)
        int r, g, b;
        if (ratio < 0.5)
        {
            var t = ratio * 2;
            r = (int)(6 + t * (139 - 6));
            g = (int)(182 + t * (92 - 182));
            b = (int)(212 + t * (246 - 212));
        }
        else
        {
            var t = (ratio - 0.5) * 2;
            r = (int)(139 + t * (236 - 139));
            g = (int)(92 + t * (72 - 92));
            b = (int)(246 + t * (153 - 246));
        }
        return $"#{r:X2}{g:X2}{b:X2}";
    }

    /// <summary>Build an SVG circle marker with the count displayed inside.</summary>
    private string BuildSvgMarker(int count, string color)
    {
        return $@"<svg xmlns='http://www.w3.org/2000/svg' width='40' height='40'>
            <circle cx='20' cy='20' r='17' fill='{color}' fill-opacity='0.85' stroke='#fff' stroke-width='2'/>
            <text x='20' y='24' text-anchor='middle' font-size='12' font-weight='800'
                  fill='#fff' font-family='system-ui,sans-serif'>{count}</text>
        </svg>";
    }

    // ── Province coordinates (approximate capital/center of each province) ──
    private static readonly ProvinceMarkerInfo[] provinceMarkers =
    [
        new("PinarDelRio",      new(22.4175, -83.6978)),
        new("Artemisa",         new(22.8133, -82.7617)),
        new("LaHabana",         new(23.0510, -82.3456)),
        new("Mayabeque",        new(22.7860, -81.9531)),
        new("Matanzas",         new(22.4119, -81.5744)),
        new("VillaClara",       new(22.4065, -79.9554)),
        new("Cienfuegos",       new(22.1507, -80.4408)),
        new("SanctiSpiritus",   new(21.9304, -79.4427)),
        new("CiegoDeAvila",     new(21.8405, -78.7628)),
        new("Camaguey",         new(21.3810, -77.9170)),
        new("LasTunas",         new(20.9600, -76.9540)),
        new("Holguin",          new(20.8872, -76.2631)),
        new("Granma",           new(20.3834, -76.6428)),
        new("SantiagoDeCuba",   new(20.2260, -75.8210)),
        new("Guantanamo",       new(20.1448, -75.2091)),
        new("IslaDeLaJuventud", new(21.7031, -82.8230)),
    ];

    private record ProvinceMarkerInfo(string Key, MapCoordinate Coordinate);
}
