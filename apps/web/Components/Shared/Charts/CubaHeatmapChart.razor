        <div class="cuba-detail">
            <div class="cuba-legend">
                <span class="cuba-legend-item">
                    <span class="cuba-legend-swatch" style="background: @GetLegendColor(0.0);"></span> Baja
                </span>
                <span class="cuba-legend-item">
                    <span class="cuba-legend-swatch" style="background: @GetLegendColor(0.33);"></span> Media
                </span>
                <span class="cuba-legend-item">
                    <span class="cuba-legend-swatch" style="background: @GetLegendColor(0.66);"></span> Alta
                </span>
                <span class="cuba-legend-item">
                    <span class="cuba-legend-swatch" style="background: @GetLegendColor(1.0);"></span> Máxima
                </span>
            </div>
            <table class="cuba-table">
                <thead>
                    <tr>
                        <th>Provincia</th>
                        <th>Imágenes</th>
                        <th>%</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Data.OrderByDescending(e => e.Count))
                    {
                        <tr>
                            <td>
                                <span class="cuba-site-dot" style="background: @GetFill(entry.Key);"></span>
                                @entry.Label
                            </td>
                            <td class="cuba-num">@entry.Count</td>
                            <td class="cuba-num">@entry.Percentage.ToString("0.0")%</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [Parameter] public IReadOnlyList<StatisticsBucketDto> Data { get; set; } = [];
    [Parameter] public string EmptyMessage { get; set; } = "Sin datos de provincia disponibles.";

    private int maxCount => Data.Count > 0 ? Math.Max(1, Data.Max(e => e.Count)) : 1;

    private string GetCount(string key)
    {
        var entry = Data.FirstOrDefault(e => e.Key == key);
        return entry?.Count.ToString() ?? "";
    }

    private string GetFill(string provinceKey)
    {
        var entry = Data.FirstOrDefault(e => e.Key == provinceKey);
        if (entry == null || entry.Count == 0)
            return "color-mix(in srgb, var(--surface-container-high) 60%, transparent)";

        var intensity = Math.Max(0.0, Math.Min(1.0, (double)entry.Count / maxCount));
        return GetLegendColor(intensity);
    }

    private string GetLegendColor(double intensity)
    {
        // Green (low) → Yellow (medium) → Red (high)
        int r, g, b;
        if (intensity <= 0.5)
        {
            var t = intensity / 0.5;
            r = (int)(t * 255);
            g = (int)(200 - t * 50);
            b = (int)(50 - t * 50);
        }
        else
        {
            var t = (intensity - 0.5) / 0.5;
            r = 255;
            g = (int)(150 - t * 120);
            b = 0;
        }

        return $"rgb({r}, {g}, {b})";
    }
}
