@page "/institutions"
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Instituciones - DermaUH</PageTitle>

<section class="institutions-hero">
    <div>
        <span class="institutions-kicker">Red colaborativa</span>
        <h1>Instituciones médicas</h1>
        <p>Conecte hospitales, universidades y centros de investigación en una red dermatológica interoperable.</p>
    </div>

    <AuthorizeView Roles="Admin">
        <Authorized>
            <button class="btn btn-primary" @onclick="() => showForm = !showForm">
                @(showForm ? "Cerrar formulario" : "Nueva institución")
            </button>
        </Authorized>
    </AuthorizeView>
</section>

<AuthorizeView Roles="Admin">
    <NotAuthorized>
        <div class="alert alert-secondary institutions-note">
            Tu rol tiene acceso de solo lectura para instituciones.
        </div>
    </NotAuthorized>
</AuthorizeView>

@if (showForm)
{
    <SectionCard Title="Registrar institución" Class="mb-4 institutions-form-card">
        <EditForm Model="newInstitution" OnValidSubmit="HandleCreate" FormName="createInstitution">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Nombre *</label>
                            <InputText @bind-Value="newInstitution.Name" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">País</label>
                            <InputText @bind-Value="newInstitution.Country" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Ciudad</label>
                            <InputText @bind-Value="newInstitution.City" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Dirección</label>
                            <InputText @bind-Value="newInstitution.Address" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Descripción</label>
                            <InputTextArea @bind-Value="newInstitution.Description" class="form-control" rows="3" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Website</label>
                            <InputText @bind-Value="newInstitution.Website" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email de Contacto</label>
                            <InputText @bind-Value="newInstitution.ContactEmail" class="form-control" />
                        </div>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary" disabled="@submitting">
                    @(submitting ? "Guardando..." : "Guardar")
                </button>
        </EditForm>
    </SectionCard>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (loading)
{
    <p><em>Cargando...</em></p>
}
else if (response is null || !response.Items.Any())
{
    <div class="alert alert-info">No se encontraron instituciones.</div>
}
else
{
    <div class="institutions-stats">
        <article>
            <span class="value">@response.TotalCount</span>
            <span class="label">Instituciones registradas</span>
        </article>
        <article>
            <span class="value">@response.Items.Count(i => !string.IsNullOrWhiteSpace(i.ContactEmail))</span>
            <span class="label">Con contacto definido</span>
        </article>
    </div>

    <section class="institutions-grid">
        @foreach (var inst in response.Items)
        {
            <article class="institution-card">
                <h3>@inst.Name</h3>
                <p>@(inst.Description ?? "Sin descripción institucional.")</p>

                <div class="institution-meta">
                    <span>@(inst.Country ?? "País no definido")</span>
                    <span>@(inst.City ?? "Ciudad no definida")</span>
                    <span>@(inst.ContactEmail ?? "Sin correo")</span>
                </div>

                <div class="institution-actions">
                    <div class="institution-action-buttons">
                        @if (!string.IsNullOrWhiteSpace(inst.Website))
                        {
                            <a href="@inst.Website" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary">Sitio web</a>
                        }
                        <AuthorizeView Roles="Admin">
                            <Authorized>
                                <button class="btn btn-outline-secondary" @onclick="() => StartEdit(inst)">Editar</button>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                    <span class="institution-date">Alta: @inst.CreatedAt.ToString("yyyy-MM-dd")</span>
                </div>
            </article>
        }
    </section>
}

@if (editingInstitutionId is not null)
{
    <SectionCard Title="Editar institución" Class="mt-4 institutions-form-card">
        <EditForm Model="editInstitution" OnValidSubmit="HandleUpdate" FormName="updateInstitution">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Nombre *</label>
                        <InputText @bind-Value="editInstitution.Name" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">País</label>
                        <InputText @bind-Value="editInstitution.Country" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ciudad</label>
                        <InputText @bind-Value="editInstitution.City" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Dirección</label>
                        <InputText @bind-Value="editInstitution.Address" class="form-control" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <InputTextArea @bind-Value="editInstitution.Description" class="form-control" rows="3" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Website</label>
                        <InputText @bind-Value="editInstitution.Website" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email de Contacto</label>
                        <InputText @bind-Value="editInstitution.ContactEmail" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Usuarios responsables</label>
                @if (allUsers.Count == 0)
                {
                    <div class="form-text">No hay usuarios disponibles para asignar.</div>
                }
                else
                {
                    <div class="responsible-users-list">
                        @foreach (var user in allUsers)
                        {
                            <label class="responsible-user-option">
                                <input type="checkbox"
                                       checked="@editResponsibleUserIds.Contains(user.Id)"
                                       @onchange="e => ToggleResponsibleUser(user.Id, e)" />
                                <span>@user.FirstName @user.LastName (@user.Email)</span>
                            </label>
                        }
                    </div>
                }
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@submittingEdit">
                    @(submittingEdit ? "Guardando..." : "Guardar cambios")
                </button>
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit" disabled="@submittingEdit">
                    Cancelar
                </button>
            </div>
        </EditForm>
    </SectionCard>
}

@code {
    private PagedResponse<InstitutionDto>? response;
    private List<UserDto> allUsers = [];
    private bool loading = true;
    private bool showForm = false;
    private bool submitting = false;
    private bool submittingEdit = false;
    private Guid? editingInstitutionId;
    private InstitutionFormModel editInstitution = new();
    private HashSet<Guid> editResponsibleUserIds = [];
    private string? errorMessage;
    private InstitutionFormModel newInstitution = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await LoadUsers();
    }

    private async Task LoadData()
    {
        loading = true;
        try
        {
            response = await Http.GetFromJsonAsync<PagedResponse<InstitutionDto>>("api/institutions?page=1&pageSize=50");
        }
        catch
        {
            response = null;
        }
        loading = false;
    }

    private async Task HandleCreate()
    {
        submitting = true;
        errorMessage = null;
        try
        {
            var result = await Http.PostAsJsonAsync("api/institutions", new
            {
                newInstitution.Name,
                newInstitution.Description,
                newInstitution.Country,
                newInstitution.City,
                newInstitution.Address,
                newInstitution.Website,
                newInstitution.ContactEmail
            });

            if (result.IsSuccessStatusCode)
            {
                newInstitution = new();
                showForm = false;
                await LoadData();
            }
            else
            {
                errorMessage = $"Error: {result.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            submitting = false;
        }
    }

    private async Task LoadUsers()
    {
        try
        {
            allUsers = [];
            var page = 1;
            const int pageSize = 100;

            while (true)
            {
                var userResponse = await Http.GetFromJsonAsync<PagedResponse<UserDto>>($"api/users?page={page}&pageSize={pageSize}");
                if (userResponse is null || !userResponse.Items.Any())
                {
                    break;
                }

                allUsers.AddRange(userResponse.Items);
                if (allUsers.Count >= userResponse.TotalCount)
                {
                    break;
                }

                page++;
            }
        }
        catch
        {
            allUsers = [];
        }
    }

    private void StartEdit(InstitutionDto institution)
    {
        editingInstitutionId = institution.Id;
        editInstitution = new InstitutionFormModel
        {
            Name = institution.Name,
            Description = institution.Description,
            Country = institution.Country,
            City = institution.City,
            Address = institution.Address,
            Website = institution.Website,
            ContactEmail = institution.ContactEmail
        };

        editResponsibleUserIds = allUsers
            .Where(u => u.InstitutionId == institution.Id)
            .Select(u => u.Id)
            .ToHashSet();
    }

    private void CancelEdit()
    {
        editingInstitutionId = null;
        editInstitution = new();
        editResponsibleUserIds.Clear();
    }

    private void ToggleResponsibleUser(Guid userId, ChangeEventArgs e)
    {
        var isChecked = e.Value is bool b && b;
        if (isChecked)
        {
            editResponsibleUserIds.Add(userId);
        }
        else
        {
            editResponsibleUserIds.Remove(userId);
        }
    }

    private async Task HandleUpdate()
    {
        if (editingInstitutionId is null)
        {
            return;
        }

        submittingEdit = true;
        errorMessage = null;
        try
        {
            var institutionId = editingInstitutionId.Value;
            var updateInstitutionResult = await Http.PutAsJsonAsync($"api/institutions/{institutionId}", new
            {
                editInstitution.Name,
                editInstitution.Description,
                editInstitution.Country,
                editInstitution.City,
                editInstitution.Address,
                editInstitution.Website,
                editInstitution.ContactEmail
            });

            if (!updateInstitutionResult.IsSuccessStatusCode)
            {
                errorMessage = $"Error al actualizar institución: {updateInstitutionResult.StatusCode}";
                return;
            }

            var usersById = new Dictionary<Guid, UserDto>();
            foreach (var user in allUsers)
            {
                usersById[user.Id] = user;
            }
            var previouslyAssigned = allUsers
                .Where(u => u.InstitutionId == institutionId)
                .Select(u => u.Id)
                .ToHashSet();

            var toAssign = editResponsibleUserIds.Except(previouslyAssigned).ToList();
            var toUnassign = previouslyAssigned.Except(editResponsibleUserIds).ToList();

            foreach (var userId in toAssign)
            {
                if (!usersById.TryGetValue(userId, out var user))
                {
                    continue;
                }

                var updateUserResult = await Http.PutAsJsonAsync($"api/users/{userId}", new
                {
                    user.FirstName,
                    user.LastName,
                    user.Email,
                    InstitutionId = institutionId
                });

                if (!updateUserResult.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al asignar responsable ({user.Email}): {updateUserResult.StatusCode}";
                    return;
                }
            }

            foreach (var userId in toUnassign)
            {
                if (!usersById.TryGetValue(userId, out var user))
                {
                    continue;
                }

                var updateUserResult = await Http.PutAsJsonAsync($"api/users/{userId}", new
                {
                    user.FirstName,
                    user.LastName,
                    user.Email,
                    InstitutionId = (Guid?)null
                });

                if (!updateUserResult.IsSuccessStatusCode)
                {
                    errorMessage = $"Error al remover responsable ({user.Email}): {updateUserResult.StatusCode}";
                    return;
                }
            }

            await LoadData();
            await LoadUsers();
            CancelEdit();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            submittingEdit = false;
        }
    }

    private class InstitutionFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? Country { get; set; }
        public string? City { get; set; }
        public string? Address { get; set; }
        public string? Website { get; set; }
        public string? ContactEmail { get; set; }
    }
}
