@page "/institutions"
@rendermode InteractiveServer
@inject HttpClient Http
@using Web.DermaImage.Shared.Models

<PageTitle>Instituciones Contribuyentes - DermaUH</PageTitle>

<section class="institutions-hero">
    <div>
        <span class="institutions-kicker">Red colaborativa</span>
        <h1>Instituciones Contribuyentes</h1>
        <p>Instituciones que han aportado imágenes a la base de datos DermaUH.</p>
    </div>
</section>

@if (loading)
{
    <p><em>Cargando...</em></p>
}
else if (institutions is null || !institutions.Any())
{
    <div class="alert alert-info">No se encontraron instituciones con imágenes aportadas.</div>
}
else
{
    <div class="institutions-stats">
        <article>
            <span class="value">@institutions.Count</span>
            <span class="label">Instituciones</span>
        </article>
        <article>
            <span class="value">@institutions.Sum(i => i.ImageCount)</span>
            <span class="label">Imágenes Totales Aportadas</span>
        </article>
    </div>

    <section class="institutions-carousel" id="institutions-carousel-region">
        <div class="institutions-track mt-4" id="institutions-carousel-track">
            @foreach (var inst in institutions)
            {
                <article class="institution-card p-4 border rounded shadow-sm flex-fill" style="min-width: 300px; max-width: 400px;">
                    <h3>@inst.Name</h3>
                    <p>@(inst.Description ?? "Sin descripción.")</p>

                    <div class="institution-meta mt-3 text-muted small">
                        <div><strong>País:</strong> @(inst.Country ?? "No definido")</div>
                        <div><strong>Imágenes Aportadas:</strong> @inst.ImageCount</div>
                    </div>
                </article>
            }
        </div>
    </section>
}
