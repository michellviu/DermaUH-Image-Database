@page "/"
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>DermaUH - Base de Datos de Imágenes Dermatológicas</PageTitle>

<section class="home-hero-panel">
    <div class="home-hero-text">
        <h1>Visualizando el futuro de la dermatología clínica</h1>
        <p>
            Plataforma especializada para instituciones médicas que necesitan imágenes dermatológicas de alta fidelidad,
            metadatos clínicos consistentes y análisis estadístico accionable.
        </p>
        <div class="home-hero-actions">
            <a href="images" class="btn btn-primary">Explorar galería</a>
            <a href="analytics" class="btn btn-outline-primary">Ver análisis estadístico</a>
        </div>
    </div>

    <div class="home-hero-metrics">
        <article>
            <span class="value">@FormatMetricValue(overview?.TotalImages)</span>
            <span class="label">Imágenes aprobadas</span>
        </article>
        <article>
            <span class="value">@FormatMetricValue(overview?.InstitutionsCount)</span>
            <span class="label">Instituciones activas</span>
        </article>
        <article>
            <span class="value">@FormatMetricValue(overview?.ContributorsCount)</span>
            <span class="label">Contribuidores activos</span>
        </article>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="alert alert-secondary mb-4">@loadError</div>
}

<section class="home-feature-grid">
    <SectionCard Class="home-feature-card">
        <h3>Galería diagnóstica</h3>
        <p>Explore imágenes curadas por tipo de lesión, sitio anatómico y categoría diagnóstica.</p>
        <a href="images" class="btn btn-outline-primary mt-auto">Abrir galería</a>
    </SectionCard>

    <SectionCard Class="home-feature-card">
        <h3>Instituciones</h3>
        <p>Gestione redes académicas y centros clínicos que alimentan el repositorio dermatológico.</p>
        <a href="institutions" class="btn btn-outline-primary mt-auto">Ver instituciones</a>
    </SectionCard>

    <SectionCard Class="home-feature-card">
        <h3>Análisis estadístico</h3>
        <p>Visualice distribución por diagnóstico, sexo, localización anatómica y tendencia mensual.</p>
        <a href="analytics" class="btn btn-outline-primary mt-auto">Ir a análisis</a>
    </SectionCard>

    <AuthorizeView Roles="Admin">
        <Authorized>
            <SectionCard Class="home-feature-card">
                <h3>Usuarios</h3>
                <p>Administre cuentas, roles y permisos institucionales desde un flujo centralizado.</p>
                <a href="users" class="btn btn-primary mt-auto">Gestionar usuarios</a>
            </SectionCard>
        </Authorized>
        <NotAuthorized>
            <SectionCard Class="home-feature-card">
                <h3>Perfil</h3>
                <p>Actualice su información profesional y mantenga sus credenciales al día.</p>
                <a href="account/profile" class="btn btn-outline-primary mt-auto">Ver mi perfil</a>
            </SectionCard>
        </NotAuthorized>
    </AuthorizeView>
</section>

@code {
    private StatisticsOverviewDto? overview;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            overview = await Http.GetFromJsonAsync<StatisticsOverviewDto>("api/statistics/overview");
        }
        catch
        {
            loadError = "No fue posible sincronizar las métricas en este momento.";
        }
    }

    private static string FormatMetricValue(int? value)
    {
        return value.HasValue ? value.Value.ToString("N0") : "-";
    }
}
