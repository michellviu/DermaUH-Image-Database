@page "/account/confirm-email/success"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@rendermode InteractiveServer

<PageTitle>Correo confirmado – DermaUH</PageTitle>

<div class="auth-container">
    <div class="auth-card text-center">
        <div class="auth-header">
            <div class="auth-logo">
                <span class="auth-logo-icon">🔬</span>
                <span class="auth-logo-text">DermaUH</span>
            </div>
            <h1 class="auth-title">Confirmación de correo</h1>
        </div>

        <div class="confirm-icon">✅</div>
        <h2 class="auth-subtitle">Confirmación exitosa</h2>
        <p class="text-muted">Tu correo fue confirmado correctamente. Ya puedes iniciar sesión.</p>

        <a href="/account/login" class="btn btn-primary mt-3">Iniciar sesión</a>
    </div>
</div>