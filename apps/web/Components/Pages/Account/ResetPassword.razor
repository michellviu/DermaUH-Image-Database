@page "/account/reset-password"
@using Web.DermaImage.Services
@using Web.DermaImage.Shared.Models
@inject AuthService Auth
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Restablecer contraseña – DermaUH</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo">
                <span class="auth-logo-icon">🔬</span>
                <span class="auth-logo-text">DermaUH</span>
            </div>
            <h1 class="auth-title">Nueva contraseña</h1>
        </div>

        @if (_success)
        {
            <div class="alert alert-success">
                Contraseña restablecida. Ya puedes iniciar sesión.
            </div>
            <div class="text-center mt-3">
                <a href="/account/login" class="btn btn-primary">Iniciar sesión</a>
            </div>
        }
        else if (string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Token))
        {
            <div class="alert alert-danger">Enlace de restablecimiento inválido.</div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger">@_errorMessage</div>
            }

            <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="ResetPwdForm">
                <div class="form-group">
                    <label class="form-label">Nueva contraseña</label>
                    <InputText class="form-control" @bind-Value="_model.NewPassword"
                               type="password" autocomplete="new-password" />
                    <small class="form-hint">Mínimo 8 caracteres, mayúscula, minúscula y número.</small>
                </div>
                <div class="form-group">
                    <label class="form-label">Confirmar contraseña</label>
                    <InputText class="form-control" @bind-Value="_model.ConfirmPassword"
                               type="password" autocomplete="new-password" />
                    @if (_mismatch)
                    {
                        <span class="text-danger small">Las contraseñas no coinciden.</span>
                    }
                </div>
                <button type="submit" class="btn btn-primary btn-full" disabled="@_loading">
                    @(_loading ? "Guardando..." : "Restablecer contraseña")
                </button>
            </EditForm>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? UserId { get; set; }
    [SupplyParameterFromQuery] public string? Token  { get; set; }

    private ResetPasswordRequest _model = new();
    private bool _loading;
    private bool _success;
    private bool _mismatch;
    private string? _errorMessage;

    private async Task HandleSubmitAsync()
    {
        _mismatch = false;
        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _mismatch = true;
            return;
        }

        _model.UserId = UserId!;
        _model.Token  = Token!;

        _loading = true;
        var (success, error) = await Auth.ResetPasswordAsync(_model);
        _loading = false;
        _success = success;
        _errorMessage = error;
    }
}
