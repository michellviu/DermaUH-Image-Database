@page "/account/forgot-password"
@using Web.DermaImage.Services
@inject AuthService Auth
@rendermode InteractiveServer

<PageTitle>Recuperar contraseña – DermaUH</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo">
                <span class="auth-logo-icon">🔬</span>
                <span class="auth-logo-text">DermaUH</span>
            </div>
            <h1 class="auth-title">Recuperar contraseña</h1>
            <p class="auth-subtitle">Te enviaremos un enlace para restablecer tu contraseña.</p>
        </div>

        @if (_success)
        {
            <div class="alert alert-success">
                Si existe una cuenta con ese correo, recibirás un email con instrucciones.
            </div>
            <div class="text-center mt-3">
                <a href="/account/login" class="btn btn-primary">Volver al inicio de sesión</a>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger">@_errorMessage</div>
            }

            <EditForm Model="_email" OnValidSubmit="HandleSubmitAsync" FormName="ForgotPwdForm">
                <div class="form-group">
                    <label class="form-label">Correo electrónico</label>
                    <input class="form-control" type="email" @bind="_email"
                           placeholder="correo@ejemplo.com" />
                </div>
                <button type="submit" class="btn btn-primary btn-full" disabled="@_loading">
                    @(_loading ? "Enviando..." : "Enviar enlace")
                </button>
            </EditForm>

            <p class="auth-footer-text">
                <a href="/account/login">← Volver al inicio de sesión</a>
            </p>
        }
    </div>
</div>

@code {
    private string _email = string.Empty;
    private bool _loading;
    private bool _success;
    private string? _errorMessage;

    private async Task HandleSubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_email)) return;
        _loading = true;
        var (success, error) = await Auth.ForgotPasswordAsync(_email);
        _loading = false;
        _success = success;
        _errorMessage = error;
    }
}
