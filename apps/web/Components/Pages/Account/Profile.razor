@page "/account/profile"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Web.DermaImage.Services
@using Web.DermaImage.Shared.Models
@attribute [Authorize]
@inject AuthService Auth
@inject NavigationManager Nav
@inject HttpClient Http
@rendermode InteractiveServer

<PageTitle>Mi perfil – DermaUH</PageTitle>

<PageHeader Title="Mi perfil" Subtitle="Actualice su información personal y credenciales de acceso." />

@if (_profile is null)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    <div class="profile-layout">

        <!-- Left: Avatar + Summary -->
        <div class="profile-sidebar">
            <div class="profile-avatar">
                <span>@(_profile.FirstName.Length > 0 ? _profile.FirstName[0].ToString().ToUpper() : "?")@(_profile.LastName.Length > 0 ? _profile.LastName[0].ToString().ToUpper() : "")</span>
            </div>
            <p class="profile-name">@_profile.FullName</p>
            <p class="profile-email">@_profile.Email</p>

            @if (_profile.EmailConfirmed)
            {
                <span class="badge badge-success">✓ Correo verificado</span>
            }
            else
            {
                <span class="badge badge-warning">⚠ Correo no verificado</span>
            }

            <div class="profile-roles mt-3">
                @foreach (var role in _profile.Roles)
                {
                    <span class="badge badge-role">@role</span>
                }
            </div>

            <p class="profile-since mt-3">
                <small class="text-muted">Miembro desde @_profile.CreatedAt.ToString("MMMM yyyy")</small>
            </p>
        </div>

        <!-- Right: Edit forms -->
        <div class="profile-content">

            <!-- Profile info -->
            <div class="card mb-4">
                <div class="card-header">
                    <h2 class="card-title">Información personal</h2>
                </div>
                <div class="card-body">

                    @if (!string.IsNullOrEmpty(_profileSuccess))
                    {
                        <div class="alert alert-success">@_profileSuccess</div>
                    }
                    @if (!string.IsNullOrEmpty(_profileError))
                    {
                        <div class="alert alert-danger">@_profileError</div>
                    }

                    <EditForm Model="_profileForm" OnValidSubmit="SaveProfileAsync" FormName="ProfileForm">
                        <DataAnnotationsValidator />

                        <div class="form-row-2">
                            <div class="form-group">
                                <label class="form-label">Nombre</label>
                                <InputText class="form-control" @bind-Value="_profileForm.FirstName" />
                                <ValidationMessage For="@(() => _profileForm.FirstName)" class="text-danger small" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Apellido</label>
                                <InputText class="form-control" @bind-Value="_profileForm.LastName" />
                                <ValidationMessage For="@(() => _profileForm.LastName)" class="text-danger small" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Correo electrónico</label>
                            <input class="form-control" value="@_profile.Email" disabled />
                            <small class="form-hint">El correo no se puede cambiar.</small>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Teléfono (opcional)</label>
                            <InputText class="form-control" @bind-Value="_profileForm.PhoneNumber"
                                       placeholder="+53 5 000 0000" type="tel" />
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary" disabled="@_savingProfile">
                                @(_savingProfile ? "Guardando..." : "Guardar cambios")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h2 class="card-title">Asociación institucional</h2>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrWhiteSpace(_membershipMessage))
                    {
                        <div class="alert alert-success">@_membershipMessage</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_membershipError))
                    {
                        <div class="alert alert-danger">@_membershipError</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Requisito para solicitar asociación</label>
                        @if (_profile.EmailConfirmed)
                        {
                            <p class="mb-2">Tu correo está confirmado y puedes enviar solicitudes.</p>
                        }
                        else
                        {
                            <p class="text-muted mb-2">Debes confirmar tu correo electrónico para enviar solicitudes de asociación.</p>
                        }
                    </div>

                    @if (_profile.InstitutionId is not null)
                    {
                        <div class="alert alert-info mb-3">
                            Ya perteneces a la institución <strong>@_profile.InstitutionName</strong>.
                        </div>
                        <button type="button" class="btn btn-outline-danger"
                                disabled="@_leavingInstitution"
                                @onclick="LeaveInstitutionAsync">
                            @(_leavingInstitution ? "Procesando..." : "Dejar de pertenecer")
                        </button>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">Solicitar pertenecer a una institución</label>
                            <div class="d-flex flex-wrap gap-2 align-items-center">
                                <select class="form-select" style="max-width: 360px;" @bind="_selectedInstitutionId">
                                    <option value="">Seleccione una institución</option>
                                    @foreach (var institution in _institutions)
                                    {
                                        <option value="@institution.Id">@institution.Name</option>
                                    }
                                </select>
                                <button class="btn btn-success"
                                        disabled="@(_sendingJoinRequest || !_canRequestInstitutionAssociation)"
                                        @onclick="SubmitJoinRequestAsync">
                                    @(_sendingJoinRequest ? "Enviando..." : "Enviar solicitud")
                                </button>
                            </div>
                            @if (!_canRequestInstitutionAssociation)
                            {
                                <small class="text-muted">Para solicitar asociación debes tener el correo confirmado.</small>
                            }
                        </div>
                    }

                    <h3 class="h6 mt-4">Mis solicitudes</h3>
                    @if (!_myJoinRequestsPage.Items.Any())
                    {
                        <p class="text-muted mb-0">No has realizado solicitudes de asociación.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Institución</th>
                                        <th>Estado</th>
                                        <th>Fecha</th>
                                        <th>Comentario</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var request in _myJoinRequestsPage.Items)
                                    {
                                        <tr>
                                            <td>@request.InstitutionName</td>
                                            <td>@MapStatus(request.Status)</td>
                                            <td>@request.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>@(string.IsNullOrWhiteSpace(request.ReviewComment) ? "-" : request.ReviewComment)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (_myJoinRequestsPage.TotalPages > 1)
                        {
                            <div class="d-flex align-items-center justify-content-between gap-2 mt-2">
                                <small class="text-muted">Página @_myJoinRequestsPage.Page de @_myJoinRequestsPage.TotalPages</small>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-secondary"
                                            disabled="@(!_myJoinRequestsPage.HasPrevious || _loadingMyJoinRequests)"
                                            @onclick="() => GoToMyJoinRequestsPageAsync(_myJoinRequestsPage.Page - 1)">
                                        Anterior
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary"
                                            disabled="@(!_myJoinRequestsPage.HasNext || _loadingMyJoinRequests)"
                                            @onclick="() => GoToMyJoinRequestsPageAsync(_myJoinRequestsPage.Page + 1)">
                                        Siguiente
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            @if (_inboxRequestsPage.TotalCount > 0)
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h2 class="card-title">Inbox de solicitudes institucionales</h2>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>Institución</th>
                                        <th>Solicitante</th>
                                        <th>Contacto</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var request in _inboxRequestsPage.Items)
                                    {
                                        <tr>
                                            <td>@request.InstitutionName</td>
                                            <td>
                                                <strong>@request.ApplicantFullName</strong><br />
                                                <small class="text-muted">@request.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                                            </td>
                                            <td>
                                                <div>@request.ApplicantEmail</div>
                                                <small class="text-muted">@request.ApplicantPhoneNumber</small>
                                            </td>
                                            <td>@MapStatus(request.Status)</td>
                                            <td>
                                                @if (request.IsPending)
                                                {
                                                    <div class="d-flex flex-column gap-2" style="min-width: 220px;">
                                                        <input class="form-control form-control-sm"
                                                               placeholder="Comentario opcional"
                                                               value="@GetReviewComment(request.Id)"
                                                               @oninput="e => SetReviewComment(request.Id, e.Value?.ToString() ?? string.Empty)" />
                                                        <div class="d-flex gap-2">
                                                            <button class="btn btn-sm btn-outline-primary"
                                                                    @onclick="() => ReviewRequestAsync(request.Id, true)">
                                                                Aprobar
                                                            </button>
                                                            <button class="btn btn-sm btn-outline-danger"
                                                                    @onclick="() => ReviewRequestAsync(request.Id, false)">
                                                                Denegar
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Revisada</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (_inboxRequestsPage.TotalPages > 1)
                        {
                            <div class="d-flex align-items-center justify-content-between gap-2 mt-2">
                                <small class="text-muted">Página @_inboxRequestsPage.Page de @_inboxRequestsPage.TotalPages</small>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-secondary"
                                            disabled="@(!_inboxRequestsPage.HasPrevious || _loadingInboxRequests)"
                                            @onclick="() => GoToInboxPageAsync(_inboxRequestsPage.Page - 1)">
                                        Anterior
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary"
                                            disabled="@(!_inboxRequestsPage.HasNext || _loadingInboxRequests)"
                                            @onclick="() => GoToInboxPageAsync(_inboxRequestsPage.Page + 1)">
                                        Siguiente
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Change password -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">Cambiar contraseña</h2>
                </div>
                <div class="card-body">

                    @if (!string.IsNullOrEmpty(_pwdSuccess))
                    {
                        <div class="alert alert-success">@_pwdSuccess</div>
                    }
                    @if (!string.IsNullOrEmpty(_pwdError))
                    {
                        <div class="alert alert-danger">@_pwdError</div>
                    }

                    <EditForm Model="_pwdForm" OnValidSubmit="ChangePasswordAsync" FormName="PasswordForm">
                        <div class="form-group">
                            <label class="form-label">Contraseña actual</label>
                            <InputText class="form-control" @bind-Value="_pwdForm.CurrentPassword"
                                       type="password" autocomplete="current-password" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Nueva contraseña</label>
                            <InputText class="form-control" @bind-Value="_pwdForm.NewPassword"
                                       type="password" autocomplete="new-password" />
                            <small class="form-hint">Mínimo 8 caracteres, mayúscula, minúscula y número.</small>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Confirmar nueva contraseña</label>
                            <InputText class="form-control" @bind-Value="_pwdForm.ConfirmPassword"
                                       type="password" autocomplete="new-password" />
                            @if (_pwdMismatch)
                            {
                                <span class="text-danger small">Las contraseñas no coinciden.</span>
                            }
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary" disabled="@_savingPwd">
                                @(_savingPwd ? "Guardando..." : "Cambiar contraseña")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>

        </div>
    </div>
}

