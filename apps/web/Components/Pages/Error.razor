@page "/Error"
@using System.Diagnostics

<PageTitle>Error - DermaUH</PageTitle>

<PageHeader Title="Ocurrió un error" Subtitle="No se pudo completar la solicitud en este momento." />

<SectionCard>
    <p>
        Puedes volver al inicio y reintentar la operación.
    </p>

    <a href="/" class="btn btn-primary mb-3">Ir al inicio</a>

    @if (ShowRequestId)
    {
        <p>
            <strong>Request ID:</strong> <code>@RequestId</code>
        </p>
    }

    <h3>Modo desarrollo</h3>
    <p>
        Si ejecutas el entorno en <strong>Development</strong> se mostrarán detalles adicionales del error.
    </p>
    <p>
        <strong>No habilites Development en producción.</strong>
        Podría exponer información sensible.
    </p>
</SectionCard>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
