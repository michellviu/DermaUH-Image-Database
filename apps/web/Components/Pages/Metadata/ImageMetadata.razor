@page "/metadata"
@rendermode InteractiveServer
@using Microsoft.JSInterop
@using System.Net.Http
@using System.Net.Http.Json
@using Web.DermaImage.Services
@using Web.DermaImage.Shared.Models
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Metadatos - DermaUH</PageTitle>

<section class="metadata-hero">
    <div class="metadata-hero-text">
        <span class="metadata-kicker">Diccionario clinico</span>
        <h1>Metadatos de imagenes dermatologicas</h1>
        <p>
            Este catalogo describe las columnas que viajan con cada descarga de imagenes.
            Use este glosario para interpretar diagnósticos, variables clinicas y detalles
            tecnicos del archivo.
        </p>
        <div class="metadata-hero-actions">
            <button type="button" class="btn btn-primary" @onclick="DownloadMetadataAsync" disabled="@(isDownloading || loading)">
                @(isDownloading ? "Descargando..." : "Descargar diccionario (CSV)")
            </button>
            <a href="images" class="btn btn-outline-primary">Ir a la galeria</a>
        </div>
        @if (!string.IsNullOrWhiteSpace(downloadError))
        {
            <div class="alert alert-danger metadata-alert">@downloadError</div>
        }
    </div>

    <div class="metadata-hero-card">
        <div class="metadata-card-header">
            <span class="metadata-card-title">Resumen rapido</span>
            <span class="metadata-card-chip">@DateTime.UtcNow.ToString("dd/MM/yyyy")</span>
        </div>
        <div class="metadata-stats">
            <div>
                <span class="metadata-stat-value">@definitions.Count</span>
                <span class="metadata-stat-label">Campos descritos</span>
            </div>
            <div>
                <span class="metadata-stat-value">@RequiredCount</span>
                <span class="metadata-stat-label">Campos obligatorios</span>
            </div>
            <div>
                <span class="metadata-stat-value">@OptionalCount</span>
                <span class="metadata-stat-label">Campos opcionales</span>
            </div>
        </div>
        <div class="metadata-card-foot">
            <span class="metadata-card-note">Las descargas de imagenes incluyen un archivo CSV con estos campos.</span>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="alert alert-secondary mt-3">@loadError</div>
}
else if (loading)
{
    <div class="alert alert-info mt-3">Cargando diccionario de metadatos...</div>
}
else
{
    <section class="metadata-table">
        <div class="metadata-table-head">
            <span>Campo</span>
            <span>Tipo</span>
            <span>Descripcion</span>
            <span>Valores / notas</span>
        </div>
        @foreach (var item in definitions)
        {
            <div class="metadata-row">
                <div class="metadata-cell">
                    <span class="metadata-key">@item.Key</span>
                    <span class="metadata-label">@item.Label</span>
                    @if (item.Required)
                    {
                        <span class="metadata-required">Obligatorio</span>
                    }
                </div>
                <div class="metadata-cell">
                    <span class="metadata-type">@item.DataType</span>
                </div>
                <div class="metadata-cell">
                    <p>@item.Description</p>
                </div>
                <div class="metadata-cell">
                    @if (!string.IsNullOrWhiteSpace(item.AllowedValues))
                    {
                        <div class="metadata-values">@item.AllowedValues</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                    {
                        <div class="metadata-notes">@item.Notes</div>
                    }
                </div>
            </div>
        }
    </section>
}

@code {
    private List<ImageMetadataDefinitionDto> definitions = [];
    private bool loading = true;
    private string? loadError;
    private bool isDownloading;
    private string? downloadError;

    private int RequiredCount => definitions.Count(d => d.Required);
    private int OptionalCount => Math.Max(0, definitions.Count - RequiredCount);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            definitions = await Http.GetFromJsonAsync<List<ImageMetadataDefinitionDto>>("api/metadata/images") ?? [];
        }
        catch
        {
            loadError = "No fue posible cargar el diccionario de metadatos.";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task DownloadMetadataAsync()
    {
        if (isDownloading)
        {
            return;
        }

        isDownloading = true;
        downloadError = null;

        try
        {
            using var response = await Http.GetAsync("api/metadata/images/download", HttpCompletionOption.ResponseHeadersRead);
            if (!response.IsSuccessStatusCode)
            {
                downloadError = await ApiValidationMessageParser.BuildFriendlyErrorMessageAsync(response);
                return;
            }

            var fallbackName = $"dermauh-metadata-{DateTime.UtcNow:yyyyMMdd}.csv";
            var fileName = ResolveFileName(response, fallbackName);
            await using var stream = await response.Content.ReadAsStreamAsync();
            using var streamRef = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("fileDownloads.downloadFileFromStream", fileName, streamRef);
        }
        catch (Exception ex)
        {
            downloadError = $"No fue posible descargar el diccionario: {ex.Message}";
        }
        finally
        {
            isDownloading = false;
        }
    }

    private static string ResolveFileName(HttpResponseMessage response, string fallback)
    {
        var contentDisposition = response.Content.Headers.ContentDisposition;
        var candidate = contentDisposition?.FileNameStar ?? contentDisposition?.FileName;
        return string.IsNullOrWhiteSpace(candidate) ? fallback : candidate.Trim('"');
    }
}
