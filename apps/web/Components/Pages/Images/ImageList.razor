@page "/images"
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Imágenes - DermaUH</PageTitle>

<section class="gallery-header">
    <div>
        <span class="gallery-kicker">Repositorio clínico</span>
        <h1>Galería diagnóstica</h1>
        <p>Filtre casos por metadatos clínicos y navegue la colección de imágenes dermatológicas verificadas.</p>
    </div>

</section>

<div class="gallery-layout">
    <aside class="gallery-filters">
        <header>
            <h2>Filtros</h2>
            <button class="btn btn-outline-secondary" @onclick="ClearFiltersAsync">Restablecer</button>
        </header>

        <section>
            <label class="form-label">Diagnóstico</label>
            <input @ref="diagnosisInputRef" type="text" value="@diagnosisContains" @oninput="OnDiagnosisInputChangedAsync" class="form-control" placeholder="Buscar por término clínico" />
        </section>

        @if (isAuthenticated)
        {
            <section>
                <label class="filter-check" for="mine-only">
                    <input class="form-check-input" type="checkbox" checked="@onlyMyContributions" @onchange="ToggleOnlyMyContributionsAsync" id="mine-only" />
                    <span>Solo mis contribuciones</span>
                </label>
            </section>
        }

        <section>
            <h3>Tipo de imagen</h3>
            @foreach (var option in imageTypeOptions)
            {
                <label class="filter-check" for="@($"type-{option.Value}")">
                    <input class="form-check-input" type="checkbox" checked="@selectedImageTypes.Contains(option.Value)" @onchange="(e) => ToggleSelection(e, option.Value, selectedImageTypes)" id="@($"type-{option.Value}")" />
                    <span>@option.Label</span>
                </label>
            }
        </section>

        <section>
            <h3>Categoría</h3>
            @foreach (var option in diagnosisCategoryOptions)
            {
                <label class="filter-check" for="@($"cat-{option.Value}")">
                    <input class="form-check-input" type="checkbox" checked="@selectedDiagnosisCategories.Contains(option.Value)" @onchange="(e) => ToggleSelection(e, option.Value, selectedDiagnosisCategories)" id="@($"cat-{option.Value}")" />
                    <span>@option.Label</span>
                </label>
            }
        </section>

        <section>
            <h3>Tipo de lesión</h3>
            @foreach (var option in injuryTypeOptions)
            {
                <label class="filter-check" for="@($"injury-{option.Value}")">
                    <input class="form-check-input" type="checkbox" checked="@selectedInjuryTypes.Contains(option.Value)" @onchange="(e) => ToggleSelection(e, option.Value, selectedInjuryTypes)" id="@($"injury-{option.Value}")" />
                    <span>@option.Label</span>
                </label>
            }
        </section>

        <section>
            <h3>Fototipo</h3>
            @foreach (var option in photoTypeOptions)
            {
                <label class="filter-check" for="@($"photo-{option.Value}")">
                    <input class="form-check-input" type="checkbox" checked="@selectedFotoTypes.Contains(option.Value)" @onchange="(e) => ToggleSelection(e, option.Value, selectedFotoTypes)" id="@($"photo-{option.Value}")" />
                    <span>@option.Label</span>
                </label>
            }
        </section>

        <section>
            <h3>Sexo</h3>
            @foreach (var option in sexOptions)
            {
                <label class="filter-check" for="@($"sex-{option.Value}")">
                    <input class="form-check-input" type="checkbox" checked="@selectedSexes.Contains(option.Value)" @onchange="(e) => ToggleSelection(e, option.Value, selectedSexes)" id="@($"sex-{option.Value}")" />
                    <span>@option.Label</span>
                </label>
            }
        </section>

        <section>
            <h3>Sitio anatómico</h3>
            @foreach (var option in anatomSiteOptions)
            {
                <label class="filter-check" for="@($"site-{option.Value}")">
                    <input class="form-check-input" type="checkbox" checked="@selectedAnatomSites.Contains(option.Value)" @onchange="(e) => ToggleSelection(e, option.Value, selectedAnatomSites)" id="@($"site-{option.Value}")" />
                    <span>@option.Label</span>
                </label>
            }
        </section>
    </aside>

    <section class="gallery-results">
        <div class="gallery-results-head">
            <div class="results-count">
                <span>@totalCount casos encontrados</span>
                @if (selectedImageIds.Count > 0)
                {
                    <span class="results-selection">@selectedImageIds.Count seleccionadas</span>
                }
            </div>
            <div class="results-actions">
                <label class="select-all-check">
                    <input class="form-check-input"
                           type="checkbox"
                           aria-label="Seleccionar todo lo cargado"
                           checked="@IsPageFullySelected"
                           disabled="@(images.Count == 0)"
                           @onchange="ToggleSelectAllOnPage" />
                    <span>Seleccionar todo lo cargado</span>
                </label>
                <div class="download-mode">
                    <label class="form-label" for="download-mode">Formato</label>
                    <select id="download-mode" class="form-select form-select-sm" @bind="downloadMode">
                        <option value="@ImageDownloadMode.ImagesAndMetadata">Imagenes y metadatos</option>
                        <option value="@ImageDownloadMode.MetadataOnly">Solo metadatos</option>
                        <option value="@ImageDownloadMode.ImagesOnly">Solo imagenes</option>
                    </select>
                </div>
                <button type="button" class="btn btn-outline-secondary" @onclick="DownloadSelectedAsync" disabled="@(selectedImageIds.Count == 0 || isDownloading)">
                    @(isDownloading ? "Descargando..." : "Descargar seleccion")
                </button>
                <button type="button" class="btn btn-primary" @onclick="DownloadAllAsync" disabled="@(totalCount == 0 || isDownloading)">
                    @(isDownloading ? "Descargando..." : "Descargar todo")
                </button>
            </div>
        </div>

        @if (loadingError is not null)
        {
            <div class="alert alert-danger">@loadingError</div>
        }

        @if (downloadError is not null)
        {
            <div class="alert alert-danger">@downloadError</div>
        }

        @if (hasLoaded && totalCount == 0)
        {
            <div class="alert alert-info">
                No se encontraron imágenes con los filtros actuales.
            </div>
        }

        <div class="images-grid">
            @foreach (var img in images)
            {
                <div class="image-card-wrap">
                    <label class="image-select" title="Seleccionar imagen">
                        <input type="checkbox"
                               aria-label="Seleccionar imagen"
                               checked="@IsImageSelected(img.Id)"
                               @onchange="(e) => ToggleImageSelection(e, img.Id)" />
                        <span class="image-select-box" aria-hidden="true"></span>
                    </label>
                    <a href="images/@img.Id" class="image-card @(IsImageSelected(img.Id) ? "image-card--selected" : string.Empty)" title="Ver detalle">
                        <ImagePreview ImageId="@img.Id" Alt="@img.FileName" />
                        <div class="image-card-footer">
                            <div class="image-name" title="@img.FileName">
                                <span class="image-name-text">@img.FileName</span>
                            </div>
                            <div class="image-meta">@(img.DiagnosisCategory ?? "—") · @(img.ImageType ?? "—")</div>
                        </div>
                    </a>
                </div>
            }
        </div>

        @if (isLoadingPage)
        {
            <div class="infinite-scroll-loading text-muted">Cargando más imágenes...</div>
        }

        @if (hasLoaded && hasMorePages && !isLoadingPage)
        {
            <div class="load-more-wrap">
                <button type="button" class="load-more-btn" @onclick="LoadMoreAsync">Ver más</button>
            </div>
        }

        <div id="@sentinelId" class="infinite-scroll-sentinel" aria-hidden="true"></div>

        @if (hasLoaded && !hasMorePages && images.Count > 0)
        {
            <div class="alert alert-secondary mt-3">No hay más imágenes para mostrar.</div>
        }
    </section>
</div>

