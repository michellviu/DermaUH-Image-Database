@page "/images/{Id:guid}"
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Detalle de Imagen - DermaUH</PageTitle>

@if (loading)
{
    <div class="alert alert-info">Cargando detalle de imagen...</div>
}
else if (image is null)
{
    <div class="alert alert-warning">Imagen no encontrada.</div>
}
else
{
    <PageHeader Title="Detalle de imagen" Subtitle="@($"ID público: {image.PublicId}")">
        <Actions>
            <a href="images" class="btn btn-outline-primary">Volver al listado</a>
        </Actions>
    </PageHeader>

    <div class="detail-grid">
        <section class="content-card detail-image-panel">
            <div class="content-card__body">
                <ImagePreview ImageId="@image.Id" Alt="@image.FileName" ContainerClass="detail-preview-wrapper" ImageClass="detail-preview-image" />
                <div class="detail-image-meta">
                    <span class="badge @(image.IsPublic ? "bg-success" : "bg-warning")">@(image.IsPublic ? "Pública" : "Privada")</span>
                    <span class="text-muted">@image.ContentType</span>
                    <span class="text-muted">@FormatFileSize(image.FileSize)</span>
                </div>
            </div>
        </section>

        <section class="space-y-3">
            <SectionCard Title="Información General">
                <div class="kv-grid">
                    @KeyValue("ID Público", image.PublicId)
                    @KeyValue("Archivo", image.FileName)
                    @KeyValue("Tipo de Imagen", image.ImageType)
                    @KeyValue("Manipulación", image.ImageManipulation)
                    @KeyValue("Tipo Dermatoscópico", image.DermoscopicType)
                    @KeyValue("Licencia", image.CopyrightLicense)
                    @KeyValue("Atribución", image.Attribution)
                    @KeyValue("Institución", image.InstitutionId?.ToString())
                </div>
            </SectionCard>

            <SectionCard Title="Datos del Paciente">
                <div class="kv-grid">
                    @KeyValue("Edad Aproximada", image.AgeApprox?.ToString())
                    @KeyValue("Sexo", image.Sex)
                    @KeyValue("Historial Personal MM", FormatBool(image.PersonalHxMm))
                    @KeyValue("Historial Familiar MM", FormatBool(image.FamilyHxMm))
                </div>
            </SectionCard>

            <SectionCard Title="Información Clínica de la Lesión">
                <div class="kv-grid">
                    @KeyValue("Sitio Anatómico", image.AnatomSiteGeneral)
                    @KeyValue("Sitio Especial", image.AnatomSiteSpecial)
                    @KeyValue("Diámetro Mayor (mm)", image.ClinSizeLongDiamMm?.ToString("F1"))
                </div>
            </SectionCard>

            <SectionCard Title="Diagnóstico">
                <div class="kv-grid">
                    @KeyValue("Diagnóstico", image.Diagnosis)
                    @KeyValue("Categoría", image.DiagnosisCategory)
                    @KeyValue("Nivel 2", image.DiagnosisLevel2)
                    @KeyValue("Nivel 3", image.DiagnosisLevel3)
                    @KeyValue("Nivel 4", image.DiagnosisLevel4)
                    @KeyValue("Nivel 5", image.DiagnosisLevel5)
                    @KeyValue("Confirmación", image.DiagnosisConfirmType)
                    @KeyValue("Melanocítico", FormatBool(image.Melanocytic))
                    @KeyValue("Biopsia Concomitante", FormatBool(image.ConcomitantBiopsy))
                </div>
            </SectionCard>

            <SectionCard Title="Histología (Melanoma)">
                <div class="kv-grid">
                    @KeyValue("Espesor (mm)", image.MelThickMm?.ToString("F2"))
                    @KeyValue("Índice Mitótico", image.MelMitoticIndex)
                    @KeyValue("Ulceración", FormatBool(image.MelUlcer))
                </div>
            </SectionCard>
        </section>
    </div>

    @if (!string.IsNullOrEmpty(image.ClinicalNotes))
    {
        <SectionCard Title="Notas Clínicas" Class="mt-4">
            <p class="whitespace-pre-wrap leading-relaxed">@image.ClinicalNotes</p>
        </SectionCard>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private DermaImgDto? image;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            image = await Http.GetFromJsonAsync<DermaImgDto>($"api/images/{Id}");
        }
        catch
        {
            image = null;
        }
        loading = false;
    }

    private string FormatBool(bool? value) => value switch
    {
        true => "Sí",
        false => "No",
        null => "—"
    };

    private string GetBadgeClass(string category) => category switch
    {
        "Benign" => "bg-success",
        "Malignant" => "bg-danger",
        "Indeterminate" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        var kb = bytes / 1024d;
        if (kb < 1024)
        {
            return $"{kb:F1} KB";
        }

        var mb = kb / 1024d;
        return $"{mb:F1} MB";
    }

    private RenderFragment KeyValue(string label, string? value) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "kv-item");

        builder.OpenElement(2, "span");
        builder.AddAttribute(3, "class", "kv-label");
        builder.AddContent(4, label);
        builder.CloseElement();

        builder.OpenElement(5, "span");
        builder.AddAttribute(6, "class", "kv-value");

        if (label == "Categoría" && !string.IsNullOrWhiteSpace(value))
        {
            builder.OpenElement(7, "span");
            builder.AddAttribute(8, "class", $"badge {GetBadgeClass(value)}");
            builder.AddContent(9, value);
            builder.CloseElement();
        }
        else
        {
            builder.AddContent(10, string.IsNullOrWhiteSpace(value) ? "—" : value);
        }

        builder.CloseElement();
        builder.CloseElement();
    };
}
