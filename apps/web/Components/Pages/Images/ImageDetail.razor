@page "/images/{Id:guid}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Detalle de Imagen - DermaUH</PageTitle>

@if (loading)
{
    <div class="alert alert-info">Cargando detalle de imagen...</div>
}
else if (image is null)
{
    <div class="alert alert-warning">Imagen no encontrada.</div>
}
else
{
    <PageHeader Title="Detalle de imagen" Subtitle="@($"ID público: {image.PublicId}")">
        <Actions>
            <a href="images" class="btn btn-outline-primary">Volver al listado</a>
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <button class="btn btn-outline-danger ms-2" @onclick="DeleteImageAsync" disabled="@deleting">
                        @(deleting ? "Eliminando..." : "Eliminar")
                    </button>
                </Authorized>
            </AuthorizeView>
        </Actions>
    </PageHeader>
    
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-3">@errorMessage</div>
    }

    <section class="detail-summary-strip">
        <span class="summary-chip @(image.IsPublic ? "summary-chip--public" : "summary-chip--private")">@(image.IsPublic ? "Pública" : "Privada")</span>
        @if (!string.IsNullOrWhiteSpace(image.DiagnosisCategory))
        {
            <span class="summary-chip">@LocalizeCategory(image.DiagnosisCategory)</span>
        }
        @if (!string.IsNullOrWhiteSpace(image.InjuryType))
        {
            <span class="summary-chip">@LocalizeInjuryType(image.InjuryType)</span>
        }
        @if (!string.IsNullOrWhiteSpace(image.InstitutionName))
        {
            <span class="summary-chip">@image.InstitutionName</span>
        }
    </section>

    <div class="detail-grid">
        <section class="content-card detail-image-panel">
            <div class="content-card__body">
                <ImagePreview ImageId="@image.Id" Alt="@image.FileName" ContainerClass="detail-preview-wrapper" ImageClass="detail-preview-image" />
                <div class="detail-image-meta">
                    <span class="detail-meta-item">Formato: @image.ContentType</span>
                    <span class="detail-meta-item">Peso: @FormatFileSize(image.FileSize)</span>
                    <span class="detail-meta-item">Creada: @image.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>
        </section>

        <section class="detail-sections">
            <SectionCard Title="Información General">
                <div class="detail-list">
                    @KeyValue("ID Público", image.PublicId)
                    @KeyValue("Archivo", image.FileName)
                    @KeyValue("Tipo de Imagen", LocalizeImageType(image.ImageType))
                    @KeyValue("Manipulación", LocalizeImageManipulation(image.ImageManipulation))
                    @KeyValue("Tipo Dermatoscópico", LocalizeDermoscopicType(image.DermoscopicType))
                    @KeyValue("Contribuidor", image.ContributorFullName)
                    @KeyValue("Institución", image.InstitutionName)
                </div>
            </SectionCard>

            <SectionCard Title="Datos del Paciente">
                <div class="detail-list">
                    @KeyValue("Edad Aproximada", image.AgeApprox?.ToString())
                    @KeyValue("Sexo", LocalizeSex(image.Sex))
                    @KeyValue("Color de Piel", LocalizeSkinColor(image.SkinColor))
                    @KeyValue("Fototipo", LocalizePhotoType(image.FotoType))
                    @KeyValue("Historial Personal", image.PersonalHistory)
                    @KeyValue("Antecedente Personal MM", FormatBool(image.PersonalHxMm))
                    @KeyValue("Antecedente Familiar MM", FormatBool(image.FamilyHxMm))
                    @KeyValue("Exposición Solar", FormatBool(image.SunExposure))
                    @KeyValue("Provincia", LocalizeProvincia(image.Provincia))
                </div>
            </SectionCard>

            <SectionCard Title="Información Clínica de la Lesión">
                <div class="detail-list">
                    @KeyValue("Sitio Anatómico", LocalizeAnatomSite(image.AnatomSiteGeneral))
                    @KeyValue("Sitio Especial", LocalizeAnatomSiteSpecial(image.AnatomSiteSpecial))
                    @KeyValue("Diámetro Mayor (mm)", image.ClinSizeLongDiamMm?.ToString("F1"))
                </div>
            </SectionCard>

            <SectionCard Title="Diagnóstico">
                <div class="detail-list">
                    @KeyValue("Diagnóstico", image.Diagnosis)
                    @KeyValue("Diag. Histopatológico", image.HistopathologicalDiagnosis)
                    @KeyValue("Categoría", image.DiagnosisCategory)
                    @KeyValue("Tipo de lesión", LocalizeInjuryType(image.InjuryType))
                    @KeyValue("Confirmación", LocalizeDiagnosisConfirmType(image.DiagnosisConfirmType))
                </div>
            </SectionCard>

            <SectionCard Title="Histología (Melanoma)">
                <div class="detail-list">
                    @KeyValue("Espesor (mm)", image.MelThickMm?.ToString("F2"))
                    @KeyValue("Índice Mitótico", image.MelMitoticIndex)
                    @KeyValue("Ulceración", FormatBool(image.MelUlcer))
                </div>
            </SectionCard>
        </section>
    </div>

    @if (!string.IsNullOrEmpty(image.DermoscopicComments))
    {
        <SectionCard Title="Comentarios Dermatoscópicos" Class="mt-4">
            <p class="whitespace-pre-wrap leading-relaxed text-sm text-[var(--on-surface-variant)]">@image.DermoscopicComments</p>
        </SectionCard>
    }

    @if (!string.IsNullOrEmpty(image.ClinicalNotes))
    {
        <SectionCard Title="Notas Clínicas" Class="mt-4">
            <p class="whitespace-pre-wrap leading-relaxed text-sm text-[var(--on-surface-variant)]">@image.ClinicalNotes</p>
        </SectionCard>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }
    private DermaImgDto? image;
    private bool loading = true;
    private bool deleting = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            image = await Http.GetFromJsonAsync<DermaImgDto>($"api/images/{Id}");
        }
        catch
        {
            image = null;
        }
        loading = false;
    }

    private string FormatBool(bool? value) => value switch
    {
        true => "Sí",
        false => "No",
        null => "—"
    };

    private string GetBadgeClass(string category) => category switch
    {
        "Benign" => "bg-success",
        "Malignant" => "bg-danger",
        "Indeterminate" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        var kb = bytes / 1024d;
        if (kb < 1024)
        {
            return $"{kb:F1} KB";
        }

        var mb = kb / 1024d;
        return $"{mb:F1} MB";
    }

    private static string LocalizeCategory(string? category) => category switch
    {
        "Benign" => "Benigno",
        "Indeterminate" => "Indeterminado",
        "Malignant" => "Maligno",
        _ => category ?? "—"
    };

    private static string LocalizeSex(string? sex) => sex switch
    {
        "Male" => "Masculino",
        "Female" => "Femenino",
        _ => sex ?? "—"
    };

    private static string LocalizeSkinColor(string? value) => value switch
    {
        "White" => "Blanco",
        "Mixed_Race" => "Mestizo",
        "Black" => "Negro",
        _ => value ?? "—"
    };

    private static string LocalizePhotoType(string? value) => value ?? "—";

    private static string LocalizeProvincia(string? value) => value switch
    {
        "PinarDelRio" => "Pinar del Río",
        "LaHabana" => "La Habana",
        "VillaClara" => "Villa Clara",
        "SanctiSpiritus" => "Sancti Spíritus",
        "CiegoDeAvila" => "Ciego de Ávila",
        "Camaguey" => "Camagüey",
        "LasTunas" => "Las Tunas",
        "SantiagoDeCuba" => "Santiago de Cuba",
        "IslaDeLaJuventud" => "Isla de la Juventud",
        _ => value ?? "—"
    };

    private static string LocalizeImageType(string? value) => value switch
    {
        "Dermoscopic" => "Dermoscópica",
        "ClinicalOverview" => "Clínica: Vista General",
        "ClinicalCloseUp" => "Clínica: Primer Plano",
        "TBPTileOverview" => "TBP: Vista General",
        "TBPTileCloseUp" => "TBP: Primer Plano",
        "RCMMacroscopic" => "RCM: Macroscópica",
        "RCMTile" => "RCM: Tile",
        "RCMMosaic" => "RCM: Mosaico",
        _ => value ?? "—"
    };

    private static string LocalizeImageManipulation(string? value) => value switch
    {
        "InstrumentOnly" => "Solo instrumento",
        "Altered" => "Alterada",
        "Synthetic" => "Sintética",
        "Unknown" => "Desconocida",
        _ => value ?? "—"
    };

    private static string LocalizeDermoscopicType(string? value) => value switch
    {
        "ContactPolarized" => "Contacto Polarizado",
        "ContactNonPolarized" => "Contacto No Polarizado",
        "NonContactPolarized" => "Sin Contacto Polarizado",
        _ => value ?? "—"
    };

    private static string LocalizeDiagnosisConfirmType(string? value) => value switch
    {
        "Histopathology" => "Histopatología",
        "SingleContributorClinicalAssessment" => "Evaluación clínica individual",
        "SerialImagingShowingNoChange" => "Imágenes seriadas sin cambio",
        "SingleImageExpertConsensus" => "Consenso de expertos",
        "ConfocalMicroscopyWithConsensusDermoscopy" => "Microscopía confocal",
        _ => value ?? "—"
    };

    private static string LocalizeInjuryType(string? value) => value switch
    {
        "Melanoma" => "Melanoma",
        "BasalCellCarcinoma" => "Carcinoma basocelular",
        "SquamousCellCarcinoma" => "Carcinoma escamocelular",
        "Others" => "Otros",
        _ => value ?? "—"
    };

    private static string LocalizeAnatomSite(string? value) => value switch
    {
        "HeadNeck" => "Cabeza/Cuello",
        "UpperExtremity" => "Extremidad Superior",
        "LowerExtremity" => "Extremidad Inferior",
        "AnteriorTorso" => "Torso Anterior",
        "LateralTorso" => "Torso Lateral",
        "PosteriorTorso" => "Torso Posterior",
        "PalmsSoles" => "Palmas/Plantas",
        "OralGenital" => "Oral/Genital",
        _ => value ?? "—"
    };

    private static string LocalizeAnatomSiteSpecial(string? value) => value switch
    {
        "AcralNOS" => "Acral (no especificado)",
        "NailNOS" => "Uña (no especificado)",
        "Fingernail" => "Uña de la mano",
        "Toenail" => "Uña del pie",
        "AcralPalmsOrSoles" => "Acral (palmas o plantas)",
        "OralOrGenital" => "Oral o genital",
        _ => value ?? "—"
    };

    private RenderFragment KeyValue(string label, string? value) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "detail-row");

        builder.OpenElement(2, "span");
        builder.AddAttribute(3, "class", "detail-label");
        builder.AddContent(4, $"{label}:");
        builder.CloseElement();

        builder.OpenElement(5, "span");
        builder.AddAttribute(6, "class", "detail-value");

        if (label == "Categoría" && !string.IsNullOrWhiteSpace(value) && value != "—")
        {
            builder.OpenElement(7, "span");
            builder.AddAttribute(8, "class", $"badge {GetBadgeClass(value)}");
            builder.AddContent(9, LocalizeCategory(value));
            builder.CloseElement();
        }
        else
        {
            builder.AddContent(10, string.IsNullOrWhiteSpace(value) ? "—" : value);
        }

        builder.CloseElement();
        builder.CloseElement();
    };

    private async Task DeleteImageAsync()
    {
        errorMessage = null;
        var confirmed = await JS.InvokeAsync<bool>("confirm", new object?[] { "¿Deseas eliminar esta imagen? Esta acción no se puede deshacer." });
        if (!confirmed)
        {
            return;
        }

        deleting = true;
        try
        {
            var response = await Http.DeleteAsync($"api/images/{Id}");
            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/images");
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                errorMessage = $"Error al eliminar: {content}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            deleting = false;
        }
    }
}
