@page "/images/create"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Contributor")]
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject AuthService Auth

<PageTitle>Nueva Imagen - DermaUH</PageTitle>

<PageHeader Title="Registrar nueva imagen" Subtitle="Capture metadatos clínicos y datos de la imagen para el repositorio.">
    <Actions>
        <a href="images" class="btn btn-outline-primary">Volver al listado</a>
    </Actions>
</PageHeader>

<SectionCard>
<EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="createImage">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success">
            <div>@successMessage</div>
            <div class="mt-2">
                <a href="/account/profile" class="btn btn-sm btn-outline-success">Ver estado en mi perfil</a>
            </div>
        </div>
    }

    <ImageClinicalMetadataForm Model="model"
                               DermoscopicEnabled="dermoscopicEnabled"
                               InjuryTypeEnabled="injuryTypeEnabled"
                               MelanomaHistologyEnabled="melanomaHistologyEnabled"
                               @bind-PersonalHxMm="personalHxMm"
                               @bind-FamilyHxMm="familyHxMm"
                               @bind-MelUlcer="melUlcer"
                               InstitutionFieldLabel="Institución del contribuidor"
                               InstitutionDisplayValue="@UserInstitutionDisplayValue"
                               InstitutionWarningMessage="Debes pertenecer a una institución para subir imágenes."
                               ShowInstitutionWarning="@string.IsNullOrWhiteSpace(model.InstitutionId)"
                               OnDependencySourceChanged="OnDependencySourceChanged">
        <FileSection>
            <h5>Selección del Archivo</h5>
            <div class="mb-3">
                <label class="form-label">Imagen *</label>
                <InputFile OnChange="OnFileSelected" accept="image/*" class="form-control" />
                @if (selectedFile is not null)
                {
                    <small class="text-muted">Archivo seleccionado: @selectedFile.Name (@(selectedFile.Size / 1024) KB)</small>
                }
            </div>

            <h5>Información del Archivo</h5>
            <div class="mb-3">
                <label class="form-label">Nombre de Archivo *</label>
                <InputText @bind-Value="model.FileName" class="form-control" readonly />
            </div>
            <div class="mb-3">
                <label class="form-label">Ruta del Archivo *</label>
                <InputText @bind-Value="model.FilePath" class="form-control" readonly />
            </div>
            <div class="mb-3">
                <label class="form-label">Tipo de Contenido</label>
                <InputText @bind-Value="model.ContentType" class="form-control" readonly />
            </div>
        </FileSection>
    </ImageClinicalMetadataForm>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" disabled="@(submitting || string.IsNullOrWhiteSpace(model.InstitutionId))">
            @(submitting ? "Enviando..." : "Enviar a revisión")
        </button>
        <a href="images" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</EditForm>
</SectionCard>

