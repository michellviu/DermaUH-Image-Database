@page "/images/{Id:guid}/edit"
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = "Admin,Contributor")]
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Editar Imagen - DermaUH</PageTitle>

<PageHeader Title="Editar imagen" Subtitle="Actualice metadatos clínicos con las mismas reglas de consistencia del registro.">
    <Actions>
        <a href="images/@Id" class="btn btn-outline-primary">Volver al detalle</a>
    </Actions>
</PageHeader>

@if (loading)
{
    <div class="alert alert-info">Cargando datos de la imagen...</div>
}
else if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="alert alert-danger">@loadError</div>
}
else
{
    <SectionCard>
        <EditForm Model="model" OnValidSubmit="HandleSubmit" FormName="editImage">
            <DataAnnotationsValidator />
            <ValidationSummary />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <ImageClinicalMetadataForm Model="model"
                                       DermoscopicEnabled="dermoscopicEnabled"
                                       InjuryTypeEnabled="injuryTypeEnabled"
                                       MelanomaHistologyEnabled="melanomaHistologyEnabled"
                                       @bind-PersonalHxMm="personalHxMm"
                                       @bind-FamilyHxMm="familyHxMm"
                                       @bind-MelUlcer="melUlcer"
                                       InstitutionFieldLabel="Institución asociada"
                                       InstitutionDisplayValue="@contributorInstitutionLabel"
                                       InstitutionDependencyNote="Se asigna automáticamente según la institución del contribuidor. Si no pertenece a ninguna, se marca como Anónimo."
                                       ShowInstitutionWarning="false"
                                       OnDependencySourceChanged="OnDependencySourceChanged">
                <FileSection>
                    <h5>Información del archivo</h5>
                    <section class="readonly-file-panel" aria-label="Información del archivo no editable">
                        <div class="readonly-file-row">
                            <span class="readonly-file-label">Nombre:</span>
                            <span class="readonly-file-value">@model.FileName</span>
                        </div>
                        <div class="readonly-file-row">
                            <span class="readonly-file-label">Tipo:</span>
                            <span class="readonly-file-value">@model.ContentType</span>
                        </div>
                        <div class="readonly-file-row">
                            <span class="readonly-file-label">Tamaño:</span>
                            <span class="readonly-file-value">@FormatFileSize(model.FileSize)</span>
                        </div>
                        <div class="dependency-note">Estos datos se conservan como referencia durante la edición.</div>
                    </section>
                </FileSection>
            </ImageClinicalMetadataForm>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@submitting">
                    @(submitting ? "Guardando cambios..." : "Guardar cambios")
                </button>
                <a href="images/@Id" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </EditForm>
    </SectionCard>
}

