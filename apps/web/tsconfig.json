{
  "compilerOptions": {
    "target": "ES2017",
    "module": "none",
    "lib": ["ES2017", "DOM"],
    "outDir": "wwwroot/js",
    "rootDir": "ts",
    "strict": true,
    "noImplicitAny": true,
    "removeComments": false,
    "sourceMap": false,
    "ignoreDeprecations": "6.0"
  },
  "include": ["ts/**/*.ts"]
}
