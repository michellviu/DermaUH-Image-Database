{
  "name": "web-dermauh",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run css:build && tsc",
    "watch": "npm run css:watch",
    "watch:ts": "tsc --watch",
    "css:build": "tailwindcss -i ./wwwroot/css/tailwind.input.css -o ./wwwroot/css/tailwind.css --minify",
    "css:watch": "tailwindcss -i ./wwwroot/css/tailwind.input.css -o ./wwwroot/css/tailwind.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}
